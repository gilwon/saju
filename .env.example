# ============================================
# Dr.Saju Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- AI (Google Gemini) ---
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

# --- Paddle Payment ---
PADDLE_API_KEY=your_paddle_api_key
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
NEXT_PUBLIC_PADDLE_PRODUCT_STAR_30=your_paddle_product_id
NEXT_PUBLIC_PADDLE_PRICE_STAR_30=your_paddle_price_id
NEXT_PUBLIC_PADDLE_PRODUCT_STAR_70=your_paddle_product_id
NEXT_PUBLIC_PADDLE_PRICE_STAR_70=your_paddle_price_id
NEXT_PUBLIC_PADDLE_PRODUCT_STAR_PREMIUM=your_paddle_product_id
NEXT_PUBLIC_PADDLE_PRICE_STAR_PREMIUM=your_paddle_price_id

# --- Email (Resend) ---
RESEND_API_KEY=your_resend_api_key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=your_admin_email@example.com

# --- Discord (Optional) ---
DISCORD_PAYMENTS_WEBHOOK_URL=your_discord_webhook_url
